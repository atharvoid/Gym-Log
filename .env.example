# GymLog Environment Configuration Template
# 
# Copy this file to '.env' in the project root:
#   cp .env.example .env
#
# Compile-time values are injected via:
#   flutter run --dart-define-from-file=.env
#   flutter build apk --release --dart-define-from-file=.env

# ==============================================================================
# 1. Supabase & Google Sign-In Configurations
# ==============================================================================
# Your Supabase Project API URL (from Project Settings -> API)
SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase Anon (Public) Key (from Project Settings -> API)
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Google OAuth Server Client ID (from Google Cloud Console -> Credentials)
# Used by native Google Sign-in to generate idTokens for Supabase Auth.
GOOGLE_SERVER_CLIENT_ID=90567853200-0o67mbmlv5qluq95q1courn77lddhcui.apps.googleusercontent.com

# ==============================================================================
# 2. RevenueCat Premium / Purchases Configurations
# ==============================================================================
# RevenueCat public API keys for premium entitlements
REVENUECAT_ANDROID_KEY=your-revenuecat-android-key-here
REVENUECAT_IOS_KEY=your-revenuecat-ios-key-here

# ==============================================================================
# 3. Sentry Crash / Error Reporting Configurations
# ==============================================================================
# Public DSN for crash reporting in the client app
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Build-time symbol upload configurations (for sentry_dart_plugin)
SENTRY_AUTH_TOKEN=your-sentry-auth-token-here
SENTRY_ORG=your-sentry-organization-slug
SENTRY_PROJECT=gymlog

# ==============================================================================
# 4. Optional Storage & Legal Overrides
# ==============================================================================
# Base URL for exercise dynamic GIF assets (do not rename the 'excercises' typo)
GIF_BUCKET_BASE=https://otcfigaprxfknickyrdh.supabase.co/storage/v1/object/public/excercises

# Privacy-compliant web account-deletion URL
ACCOUNT_DELETION_URL=https://atharvoid.github.io/Gym-Log/legal/delete-account.html
